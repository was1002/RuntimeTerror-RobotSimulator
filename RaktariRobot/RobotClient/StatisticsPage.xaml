<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RobotClient"
             x:DataType="local:StatisticsViewModel"
             x:Class="RobotClient.StatisticsPage"
             Title="Warehouse Statistics"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Live Robot Statistics" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />

            <Border BackgroundColor="#1E1E1E" Stroke="#333333" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding TotalRobots, StringFormat='Total Robots: {0}'}" TextColor="White" FontSize="18" />
                    <Label Text="{Binding WorkingRobots, StringFormat='Working: {0}'}" TextColor="Green" FontSize="18"/>
                    <Label Text="{Binding ChargingRobots, StringFormat='Charging: {0}'}" TextColor="Yellow" FontSize="18"/>
                    <Label Text="{Binding ErrorRobots, StringFormat='In Error State: {0}'}" TextColor="Red" FontSize="18"/>
                </VerticalStackLayout>
            </Border>

            <Button Text="Refresh Statistics" Command="{Binding RefreshCommand}" BackgroundColor="#1E90FF" TextColor="White" FontAttributes="Bold" CornerRadius="8" Padding="10"/>
            <Button Text="Close" Clicked="CloseButton_Clicked" BackgroundColor="#555555" TextColor="White" FontAttributes="Bold" CornerRadius="8" Padding="10"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>