<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RuntimeTerror.Client"
             xmlns:selectors="clr-namespace:RuntimeTerror.Client.Selectors"
             x:Class="RobotClient.MainPage"
             Title="Runtime Terror - Robot Szimulátor">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <!-- Data Templates for Robot List -->
            <DataTemplate x:Key="NormalRobotTemplate">
                <ContentView Padding="10,8">
                    <HorizontalStackLayout Spacing="10">
                        <Ellipse WidthRequest="10" HeightRequest="10" Fill="Green" VerticalOptions="Center"/>
                        <Label Text="{Binding DisplayName}" TextColor="White" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                    </HorizontalStackLayout>
                </ContentView>
            </DataTemplate>

            <DataTemplate x:Key="WarningRobotTemplate">
                <ContentView Padding="10,8" BackgroundColor="#4A4A00">
                    <HorizontalStackLayout Spacing="10">
                        <Ellipse WidthRequest="10" HeightRequest="10" Fill="Yellow" VerticalOptions="Center"/>
                        <Label Text="{Binding DisplayName}" TextColor="Yellow" FontAttributes="Bold" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                    </HorizontalStackLayout>
                </ContentView>
            </DataTemplate>

            <DataTemplate x:Key="ErrorRobotTemplate">
                <ContentView Padding="10,8" BackgroundColor="#4A0000">
                    <HorizontalStackLayout Spacing="10">
                        <Ellipse WidthRequest="10" HeightRequest="10" Fill="Red" VerticalOptions="Center"/>
                        <Label Text="{Binding DisplayName}" TextColor="#FF6B6B" FontAttributes="Bold" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                    </HorizontalStackLayout>
                </ContentView>
            </DataTemplate>

            <selectors:RobotStateTemplateSelector x:Key="RobotStateSelector"
                NormalTemplate="{StaticResource NormalRobotTemplate}"
                WarningTemplate="{StaticResource WarningRobotTemplate}"
                ErrorTemplate="{StaticResource ErrorRobotTemplate}" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <local:MainViewModel />
    </ContentPage.BindingContext>

    <Grid ColumnDefinitions="4*, 6*" RowDefinitions="60, *, 220" ColumnSpacing="10" RowSpacing="10" Padding="10" BackgroundColor="#121212">
        
        <!-- Project name -->
        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#1E1E1E" Stroke="#333333" StrokeThickness="1" StrokeShape="RoundRectangle 8">
            <Label Text="Runtime Terror" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" />
        </Border>

        <!-- General controls -->
        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#1E1E1E" Stroke="#333333" StrokeThickness="1" StrokeShape="RoundRectangle 8">
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
                <Label Text="General controls" FontAttributes="Bold" VerticalOptions="Center" Margin="0,0,20,0" TextColor="#BDBDBD"/>
                <Button Text="{Binding SimulationButtonText}" Command="{Binding ToggleSimulationCommand}"/>
                <Button Text="Reset" Command="{Binding ResetSimulationCommand}"/>
                <Button Text="Simple/Detailed view" />
            </HorizontalStackLayout>
        </Border>

        <!-- Robot list and Toggleable info -->
        <Grid Grid.Row="1" Grid.Column="0" RowDefinitions="*, Auto" RowSpacing="10">
            <!-- Robot list -->
            <Border Grid.Row="0" BackgroundColor="#1E1E1E" Stroke="#333333" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                <Grid RowDefinitions="Auto, *">
                    <Label Grid.Row="0" Text="Robot list" FontAttributes="Bold" Margin="10,10,10,5" TextColor="#BDBDBD"/>
                    <HorizontalStackLayout Grid.Row="0" HorizontalOptions="End" Spacing="5" Margin="5">
                        <Entry Placeholder="Name" Text="{Binding InputNewName}" WidthRequest="100" />
                        <Button Text="Add" Command="{Binding AddRobotCommand}" Padding="5,0"/>
                        <Button Text="Rename" Command="{Binding RenameRobotCommand}" Padding="5,0"/>
                        <Button Text="Remove" Command="{Binding RemoveRobotCommand}" Padding="5,0"/>
                    </HorizontalStackLayout>
                    <CollectionView Grid.Row="1" Margin="5" ItemsSource="{Binding RobotsList}" SelectedItem="{Binding SelectedRobot}" SelectionMode="Single"
                                    ItemTemplate="{StaticResource RobotStateSelector}">
                    </CollectionView>
                </Grid>
            </Border>

            <!-- Toggleable detailed informations -->
            <Border Grid.Row="1" BackgroundColor="#1E1E1E" Stroke="#333333" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="150" IsVisible="True">
                <ScrollView>
                    <VerticalStackLayout Margin="10">
                        <Label Text="Detailed informations for selected robot" FontAttributes="Bold" TextColor="#BDBDBD"/>
                        <Label Text="{Binding SelectedRobot.DisplayName, StringFormat='Name: {0}'}" TextColor="White" Margin="0,5,0,0"/>
                        <Label Text="{Binding SelectedRobot.State, StringFormat='State: {0}'}" TextColor="White"/>
                        <Label Text="{Binding SelectedRobot.BatteryLevel, StringFormat='Battery: {0}%'}" TextColor="White"/>
                        <Label Text="{Binding SelectedRobot.DiagnosticLevel, StringFormat='Diagnostics: {0}'}" TextColor="White"/>
                        <Label Text="{Binding SelectedRobot.LastErrorMessage, StringFormat='Last Error: {0}'}" TextColor="Red"/>
                        <Label Text="No robot selected." TextColor="Gray" IsVisible="{Binding HasSelectedRobot, Converter={x:StaticResource InvertedBoolConverter}}" Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <!-- Map -->
        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#161616" Stroke="#333333" StrokeThickness="1" StrokeShape="RoundRectangle 8">
            <Grid>
                <Label Text="Map" FontAttributes="Bold" Margin="10" ZIndex="1" TextColor="#BDBDBD"/>
                <ScrollView Orientation="Both" HorizontalOptions="Center" VerticalOptions="Center">
                    <AbsoluteLayout WidthRequest="400" HeightRequest="280">
                        <!-- Térkép Cella réteg -->
                        <AbsoluteLayout BindableLayout.ItemsSource="{Binding MapCells}" WidthRequest="400" HeightRequest="280">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border AbsoluteLayout.LayoutBounds="{Binding Bounds}" 
                                            AbsoluteLayout.LayoutFlags="None"
                                            BackgroundColor="{Binding BgColor}"
                                            Stroke="Black" StrokeThickness="1">
                                        <Label Text="{Binding Icon}" 
                                               TextColor="{Binding TextColor}"
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center" 
                                               FontAttributes="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </AbsoluteLayout>

                        <!-- Robot réteg -->
                        <AbsoluteLayout BindableLayout.ItemsSource="{Binding MapRobots}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse AbsoluteLayout.LayoutBounds="{Binding Bounds}"
                                             AbsoluteLayout.LayoutFlags="None"
                                             Fill="{Binding RobotColor}"
                                             Stroke="Black" StrokeThickness="2" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </AbsoluteLayout>
                    </AbsoluteLayout>
                </ScrollView>
            </Grid>
        </Border>

        <!-- Robot movement and diagnostic controls -->
        <Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="6*, 4*" ColumnSpacing="10" BackgroundColor="Transparent">
            <!-- Movement -->
            <Border Grid.Column="0" BackgroundColor="#1E1E1E" Stroke="#333333" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                <Grid RowDefinitions="Auto, *">
                    <Label Grid.Row="0" Text="Robot movement controls" FontAttributes="Bold" Margin="10,10,10,5" TextColor="#BDBDBD"/>
                    <VerticalStackLayout Grid.Row="1" Spacing="5" Margin="10,0,10,10">
                        <HorizontalStackLayout Spacing="5">
                            <Button Text="Start" Command="{Binding ResumeRobotCommand}" />
                            <Button Text="Pause" Command="{Binding PauseRobotCommand}" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="5">
                            <Button Text="To Charger" Command="{Binding MoveToChargerCommand}" />
                            <Button Text="To Service" Command="{Binding MoveToServiceCommand}" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="5">
                            <Entry Placeholder="X" Text="{Binding ManualTargetX}" WidthRequest="40" Keyboard="Numeric"/>
                            <Entry Placeholder="Y" Text="{Binding ManualTargetY}" WidthRequest="40" Keyboard="Numeric"/>
                            <Button Text="Set" Command="{Binding SetLocationCommand}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Diagnostics Controls -->
            <Border Grid.Column="1" BackgroundColor="#1E1E1E" Stroke="#333333" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                <Grid RowDefinitions="Auto, *">
                    <Label Grid.Row="0" Text="Robot diagnostic controls" FontAttributes="Bold" Margin="10,10,10,5" TextColor="#BDBDBD"/>
                    <VerticalStackLayout Grid.Row="1" Spacing="5" Margin="10,0,10,10">
                        <Button Text="Clear warning" Command="{Binding ClearWarningCommand}" />
                        <Button Text="Fix error" Command="{Binding FixErrorCommand}" />
                        <Button Text="Simulate fault" Command="{Binding SimulateFaultCommand}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!-- Diagnostics App Wide -->
        <Border Grid.Row="2" Grid.Column="1" BackgroundColor="#1E1E1E" Stroke="#333333" StrokeThickness="1" StrokeShape="RoundRectangle 8">
            <Grid RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="Diagnostics (errors, warnings)" FontAttributes="Bold" Margin="10,10,10,5" TextColor="#BDBDBD"/>
                <ScrollView Grid.Row="1" Margin="10,0,10,10">
                    <VerticalStackLayout>
                        <Label Text="{Binding AppMessage}" TextColor="#FF6B6B" />
                        <Label Text="No other warnings." TextColor="White"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
        
    </Grid>
</ContentPage>