<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RuntimeTerror.Client"
             x:Class="RobotClient.MainPage"
             Title="Runtime Terror - Robot Szimulátor">

    <ContentPage.BindingContext>
        <local:MainViewModel />
    </ContentPage.BindingContext>

    <Grid ColumnDefinitions="300, *" RowDefinitions="*" Padding="10">

        <VerticalStackLayout Grid.Column="0" Spacing="20" Padding="10" BackgroundColor="#2C2C2C">

            <Label Text="MŰSZERFAL" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
            <BoxView HeightRequest="1" Color="Gray"/>

            <Label Text="{Binding State, StringFormat='Állapot: {0}'}" TextColor="LightGreen" FontSize="16"/>
            <Label Text="{Binding Battery, StringFormat='Akkumulátor: {0}%'}" TextColor="Yellow" FontSize="16"/>
            <Label Text="{Binding X, StringFormat='X pozíció: {0:F1}'}" TextColor="White"/>
            <Label Text="{Binding Y, StringFormat='Y pozíció: {0:F1}'}" TextColor="White"/>

            <Label Text="{Binding ErrorMessage}" TextColor="Red" FontAttributes="Bold"/>

            <BoxView HeightRequest="1" Color="Gray"/>

            <Label Text="VEZÉRLÉS" FontSize="16" FontAttributes="Bold" TextColor="White"/>
            <Button Text="⬆ Előre" Command="{Binding MoveForwardCommand}" BackgroundColor="#1E90FF"/>
            <Button Text="Csomag felvétele" Command="{Binding PickUpCommand}" BackgroundColor="#32CD32"/>

            <BoxView HeightRequest="1" Color="Gray"/>

            <Button Text="VÉSZMEGÁLLÁS" 
                    Command="{Binding EmergencyStopCommand}" 
                    BackgroundColor="Red" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    HeightRequest="60" 
                    CornerRadius="30"/>
        </VerticalStackLayout>

        <Border Grid.Column="1" Stroke="Gray" StrokeThickness="2" Margin="10,0,0,0">
            <ScrollView Orientation="Both" HorizontalOptions="Center" VerticalOptions="Center">
                <AbsoluteLayout WidthRequest="400" HeightRequest="280">
                    <!-- Térkép Cella réteg -->
                    <AbsoluteLayout BindableLayout.ItemsSource="{Binding MapCells}" WidthRequest="400" HeightRequest="280">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border AbsoluteLayout.LayoutBounds="{Binding Bounds}" 
                                        AbsoluteLayout.LayoutFlags="None"
                                        BackgroundColor="{Binding BgColor}"
                                        Stroke="Black" StrokeThickness="1">
                                    <Label Text="{Binding Icon}" 
                                           TextColor="{Binding TextColor}"
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center" 
                                           FontAttributes="Bold"/>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </AbsoluteLayout>

                    <!-- Robot réteg (később ide jöhetnek a robotok) -->
                    <AbsoluteLayout BindableLayout.ItemsSource="{Binding Robots}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Ellipse AbsoluteLayout.LayoutBounds="{Binding Bounds}"
                                         AbsoluteLayout.LayoutFlags="None"
                                         Fill="{Binding RobotColor}"
                                         Stroke="Black" StrokeThickness="2" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </AbsoluteLayout>
                </AbsoluteLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>